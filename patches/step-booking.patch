================================================
INSTRUCTIONS D'APPLICATION DU PATCH 2
================================================

Fichier cible :
  {motopress-hotel-booking}/includes/shortcodes/checkout-shortcode/step-booking.php

Ce patch modifie la méthode parseBookingData() pour que les room types
avec la meta _mphb_hourly_enabled = 1 passent la validation sans rate_id.

CHANGEMENT 1 — Validation rate_id non-null (vers ligne ~80 dans la boucle)
Chercher :
    $rateId = isset( $roomDetails['rate_id'] ) ? \MPHB\Utils\ValidateUtils::validateInt( $roomDetails['rate_id'] ) : null;
    if ( ! $rateId ) {
        $errors[] = __( 'Rate is not valid.', 'motopress-hotel-booking' );
        break;
    }

Remplacer par :
    $rateId = isset( $roomDetails['rate_id'] ) ? \MPHB\Utils\ValidateUtils::validateInt( $roomDetails['rate_id'] ) : null;
    $isHourlyRoom = (bool) get_post_meta( $roomTypeId, '_mphb_hourly_enabled', true );
    if ( ! $rateId && ! $isHourlyRoom ) {
        $errors[] = __( 'Rate is not valid.', 'motopress-hotel-booking' );
        break;
    }

------------------------------------------------------

CHANGEMENT 2 — Validation rate_id dans les allowed rates
Chercher :
    if ( ! in_array( $rateId, $allowedRatesIds ) ) {
        $errors[] = __( 'Rate is not valid.', 'motopress-hotel-booking' );
        break;
    }

Remplacer par :
    if ( ! $isHourlyRoom && ! in_array( $rateId, $allowedRatesIds ) ) {
        $errors[] = __( 'Rate is not valid.', 'motopress-hotel-booking' );
        break;
    }

------------------------------------------------------

CHANGEMENT 3 — isBookingRulesViolated() bypass
Chercher :
    if ( mphb_availability_facade()->isBookingRulesViolated(
            $roomType->getOriginalId(),
            $this->checkInDate,
            $this->checkOutDate,
            $isIgnoreBookingRules
        )
    ) {
        $this->errors[] = sprintf( __( 'Selected dates do not meet booking rules for type %s', 'motopress-hotel-booking' ), $roomType->getTitle() );
        break;
    }

Remplacer par :
    if ( ! $isHourlyRoom && mphb_availability_facade()->isBookingRulesViolated(
            $roomType->getOriginalId(),
            $this->checkInDate,
            $this->checkOutDate,
            $isIgnoreBookingRules
        )
    ) {
        $this->errors[] = sprintf( __( 'Selected dates do not meet booking rules for type %s', 'motopress-hotel-booking' ), $roomType->getTitle() );
        break;
    }

